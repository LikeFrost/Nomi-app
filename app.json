{
  "expo": {
    "name": "Nomi",
    "slug": "Nomi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/nomi.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/nomi.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF2F8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/nomi.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.likefrost.myapp"
    },
    "web": {
      "favicon": "./assets/nomi.png"
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "faba8255-b85e-4a58-8c47-723e7a6ce7f2"
      }
    }
  }
}